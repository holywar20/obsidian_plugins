{
	"name": "embedded-terminal",
	"version": "1.0.0",
	"description": "PowerShell and Git Bash terminals embedded as tabs in Obsidian.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production"
	},
	"dependencies": {
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.21.0",
		"obsidian": "latest",
		"typescript": "^5.4.0"
	}
}
